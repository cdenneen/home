#!/usr/bin/env bash
set -euo pipefail

ts() {
  date '+%Y-%m-%d %H:%M:%S'
}

resolve_repo_dir() {
  local candidate
  local roots=()

  if [ -n "${WORKSPACE_ROOT:-}" ]; then
    roots+=("$WORKSPACE_ROOT")
  fi

  roots+=(
    "$HOME/code/workspace"
    "$HOME/src/workspace"
  )

  for root in "${roots[@]}"; do
    candidate="$root/nix/home"
    if [ -x "$candidate/scripts/launch-oci-ghost.sh" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}"
run_dir="$state_dir/oci-ghost-runs"
mkdir -p "$run_dir"

lock_dir="$state_dir/oci-ghost-build.lock.d"
lock_pid_file="$lock_dir/pid"

pid_is_ghost_builder() {
  local pid="$1"
  local cmd=""

  cmd="$(ps -o command= -p "$pid" 2>/dev/null || true)"
  [ -n "$cmd" ] && printf '%s' "$cmd" | grep -Fq "oci-build-oracle-cloud-nixos.sh"
}

if [ -d "$lock_dir" ]; then
  lock_pid=""
  if [ -r "$lock_pid_file" ]; then
    lock_pid="$(cat "$lock_pid_file" 2>/dev/null || true)"
  fi

  if [ -n "$lock_pid" ] && kill -0 "$lock_pid" 2>/dev/null && pid_is_ghost_builder "$lock_pid"; then
    echo "[$(ts)] ghost builder already running (lock pid: $lock_pid)"
    exit 0
  fi

  echo "[$(ts)] found stale lock at $lock_dir; removing"
  rm -rf "$lock_dir"
fi

if ! repo_dir="$(resolve_repo_dir)"; then
  echo "[$(ts)] could not find nix/home repo from WORKSPACE_ROOT or default paths" >&2
  exit 1
fi

echo "[$(ts)] starting ghost builder from $repo_dir"
cd "$repo_dir"
exec "$repo_dir/scripts/launch-oci-ghost.sh" --wait
