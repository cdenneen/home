#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: deploy-jarvis <ghost|nyx|mac>

Deploys the Jarvis flake wiring for the selected target and verifies the
expected local health endpoints after the switch.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || $# -lt 1 ]]; then
  usage
  exit "${1:+0}"
fi

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "deploy-jarvis: missing required command: $1" >&2
    exit 1
  }
}

find_repo_dir() {
  local override="$1"
  shift
  local candidate

  if [[ -n "$override" && -e "$override/.git" ]]; then
    printf '%s\n' "$override"
    return 0
  fi

  for candidate in "$@"; do
    if [[ -n "$candidate" && -e "$candidate/.git" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

assert_repo_pushed() {
  local repo_dir="$1"
  local label="$2"
  local remote="${3:-origin}"

  if [[ ! -e "$repo_dir/.git" ]]; then
    echo "deploy-jarvis: $label repo not found at $repo_dir" >&2
    exit 1
  fi

  if [[ -n "$(git -C "$repo_dir" status --porcelain)" ]]; then
    echo "deploy-jarvis: $label repo has uncommitted changes at $repo_dir" >&2
    echo "deploy-jarvis: commit/stash before deploying" >&2
    exit 1
  fi

  local branch
  branch="$(git -C "$repo_dir" rev-parse --abbrev-ref HEAD)"
  if [[ "$branch" == "HEAD" ]]; then
    echo "deploy-jarvis: $label repo is in detached HEAD at $repo_dir" >&2
    exit 1
  fi

  local local_head remote_head
  local_head="$(git -C "$repo_dir" rev-parse HEAD)"
  remote_head="$(git -C "$repo_dir" ls-remote "$remote" "refs/heads/$branch" | awk 'NR==1 { print $1 }')"

  if [[ -z "$remote_head" ]]; then
    echo "deploy-jarvis: unable to resolve $label remote tip for $remote/$branch" >&2
    exit 1
  fi

  if [[ "$local_head" != "$remote_head" ]]; then
    echo "deploy-jarvis: $label local HEAD $local_head != pushed $remote/$branch tip $remote_head" >&2
    echo "deploy-jarvis: push your changes first, then rerun deploy-jarvis" >&2
    exit 1
  fi
}

wait_for_url() {
  local url="$1"
  local attempts="${2:-30}"
  local sleep_seconds="${3:-2}"
  local attempt

  for attempt in $(seq 1 "$attempts"); do
    if curl -fsS -o /dev/null --connect-timeout 2 --max-time 5 "$url" >/dev/null 2>&1; then
      return 0
    fi
    sleep "$sleep_seconds"
  done

  echo "deploy-jarvis: timed out waiting for $url" >&2
  return 1
}

require_cmd curl
require_cmd git

detect_tailscale_cmd() {
  if command -v tailscale >/dev/null 2>&1; then
    command -v tailscale
    return 0
  fi

  if [[ -x /Applications/Tailscale.app/Contents/MacOS/Tailscale ]]; then
    printf '%s\n' "/Applications/Tailscale.app/Contents/MacOS/Tailscale"
    return 0
  fi

  return 1
}

app_repo_dir="$({
  find_repo_dir "${DEPLOY_JARVIS_APP_SOURCE:-}" \
    "$HOME/code/workspace/personal/jarvis" \
    "$HOME/src/workspace/personal/jarvis"
} || true)"
flake_repo_dir="$({
  find_repo_dir "${DEPLOY_JARVIS_FLAKE_SOURCE:-}" \
    "$HOME/code/workspace/nix/home" \
    "$HOME/src/workspace/nix/home"
} || true)"

if [[ -z "$app_repo_dir" ]]; then
  echo "deploy-jarvis: unable to locate local app repo checkout" >&2
  exit 1
fi

if [[ -z "$flake_repo_dir" ]]; then
  echo "deploy-jarvis: unable to locate local flake repo checkout" >&2
  exit 1
fi

assert_repo_pushed "$app_repo_dir" "jarvis app"
assert_repo_pushed "$flake_repo_dir" "nix/home flake"

target="$1"

case "$target" in
  ghost)
    require_cmd ssh
    remote_script=$(cat <<'EOF'
set -euo pipefail
export PATH="$HOME/.nix-profile/bin:/run/current-system/sw/bin:$PATH"

sudo_cmd=/run/wrappers/bin/sudo
if [[ ! -x "$sudo_cmd" ]]; then
  sudo_cmd="$(command -v sudo)"
fi
git_cmd="$(command -v git)"
nixos_rebuild_cmd="$(command -v nixos-rebuild)"
systemctl_cmd="$(command -v systemctl)"
ssh_keygen_cmd="$(command -v ssh-keygen)"
ssh_keyscan_cmd="$(command -v ssh-keyscan)"

jarvis_repo_dir="/opt/jarvis"
jarvis_repo_url="git@gitlab.com:cdenneen/my-jarvis.git"
jarvis_known_hosts_file="/home/cdenneen/.ssh/known_hosts"

if [ ! -d "$jarvis_repo_dir/.git" ]; then
  "$sudo_cmd" install -d -m 0755 -o cdenneen -g users "$jarvis_repo_dir"
  "$sudo_cmd" install -d -m 0700 -o cdenneen -g users /home/cdenneen/.ssh
  "$sudo_cmd" touch "$jarvis_known_hosts_file"
  "$sudo_cmd" chown cdenneen:users "$jarvis_known_hosts_file"
  "$sudo_cmd" chmod 0600 "$jarvis_known_hosts_file"
  if ! "$ssh_keygen_cmd" -F gitlab.com -f "$jarvis_known_hosts_file" >/dev/null 2>&1; then
    "$ssh_keyscan_cmd" -H gitlab.com >> "$jarvis_known_hosts_file"
  fi
  "$sudo_cmd" -u cdenneen "$git_cmd" clone "$jarvis_repo_url" "$jarvis_repo_dir"
fi

"$sudo_cmd" -u cdenneen "$git_cmd" -C "$jarvis_repo_dir" pull --rebase

cd ~/src/workspace/nix/home
git pull --rebase
"$sudo_cmd" "$nixos_rebuild_cmd" switch --flake .#ghost

for unit in jarvis-harness.service jarvis-api.service jarvis-slack-gateway.service jarvis-web.service; do
  "$sudo_cmd" "$systemctl_cmd" is-active --quiet "$unit"
done

curl -fsS http://127.0.0.1:8080/healthz >/dev/null
curl -fsS http://127.0.0.1:8081/healthz >/dev/null
curl -fsS http://127.0.0.1:3000 >/dev/null
EOF
)
    ssh -o ClearAllForwardings=yes ghost "bash -lc $(printf '%q' "$remote_script")"
    ;;
  nyx)
    require_cmd ssh
    remote_script=$(cat <<'EOF'
set -euo pipefail
export PATH="$HOME/.nix-profile/bin:/run/current-system/sw/bin:$PATH"

sudo_cmd=/run/wrappers/bin/sudo
if [[ ! -x "$sudo_cmd" ]]; then
  sudo_cmd="$(command -v sudo)"
fi
git_cmd="$(command -v git)"
nixos_rebuild_cmd="$(command -v nixos-rebuild)"
systemctl_cmd="$(command -v systemctl)"
ssh_keygen_cmd="$(command -v ssh-keygen)"
ssh_keyscan_cmd="$(command -v ssh-keyscan)"

jarvis_repo_dir="/opt/jarvis"
jarvis_repo_url="git@gitlab.com:cdenneen/my-jarvis.git"
jarvis_known_hosts_file="/home/cdenneen/.ssh/known_hosts"

if [ ! -d "$jarvis_repo_dir/.git" ]; then
  "$sudo_cmd" install -d -m 0755 -o cdenneen -g users "$jarvis_repo_dir"
  "$sudo_cmd" install -d -m 0700 -o cdenneen -g users /home/cdenneen/.ssh
  "$sudo_cmd" touch "$jarvis_known_hosts_file"
  "$sudo_cmd" chown cdenneen:users "$jarvis_known_hosts_file"
  "$sudo_cmd" chmod 0600 "$jarvis_known_hosts_file"
  if ! "$ssh_keygen_cmd" -F gitlab.com -f "$jarvis_known_hosts_file" >/dev/null 2>&1; then
    "$ssh_keyscan_cmd" -H gitlab.com >> "$jarvis_known_hosts_file"
  fi
  "$sudo_cmd" -u cdenneen "$git_cmd" clone "$jarvis_repo_url" "$jarvis_repo_dir"
fi

"$sudo_cmd" -u cdenneen "$git_cmd" -C "$jarvis_repo_dir" pull --rebase

cd ~/src/workspace/nix/home
git pull --rebase
"$sudo_cmd" "$nixos_rebuild_cmd" switch --flake .#nyx

"$sudo_cmd" "$systemctl_cmd" is-active --quiet jarvis-work-runner.service
curl -fsS http://127.0.0.1:8090/healthz >/dev/null
EOF
)
    ssh -o ClearAllForwardings=yes nyx "bash -lc $(printf '%q' "$remote_script")"
    ;;
  mac)
    require_cmd home-manager
    tailscale_cmd="$(detect_tailscale_cmd)" || {
      echo "deploy-jarvis: tailscale CLI not found on Mac" >&2
      exit 1
    }
    cd ~/code/workspace/nix/home
    git pull --rebase
    home-manager switch --flake .#cdenneen@VNJTECMBCD
    launchctl list | grep -q "jarvis-voice-edge"
    launchctl list | grep -q "jarvis-mac-runner"
    mac_tailscale_ip="$("$tailscale_cmd" ip -4 | head -n 1)"
    if [[ -z "$mac_tailscale_ip" ]]; then
      echo "deploy-jarvis: unable to determine Mac tailscale IP" >&2
      exit 1
    fi
    wait_for_url "http://${mac_tailscale_ip}:8091/healthz" 20 2
    "${HOME}/.local/bin/jarvis-voice-edge-status" || true
    "${HOME}/.local/bin/jarvis-mac-runner-status" || true
    ;;
  *)
    echo "deploy-jarvis: unsupported target '$target'" >&2
    exit 1
    ;;
esac
