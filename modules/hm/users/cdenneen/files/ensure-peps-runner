#!/usr/bin/env bash
set -euo pipefail

resolve_repo_dir() {
  local candidate
  local roots=()

  if [ -n "${WORKSPACE_ROOT:-}" ]; then
    roots+=("$WORKSPACE_ROOT")
  fi

  roots+=(
    "$HOME/code/workspace"
    "$HOME/src/workspace"
  )

  for root in "${roots[@]}"; do
    candidate="$root/peps"
    if [ -x "$candidate/scripts/pep-service-runner.sh" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

if ! repo_dir="$(resolve_repo_dir)"; then
  echo "Could not find peps repo from WORKSPACE_ROOT or default paths." >&2
  exit 1
fi

cd "$repo_dir"
exec "$repo_dir/scripts/pep-service-runner.sh"
