#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: cf-move-published-routes [--also-dns] <ghost|nyx|mac> [hostname...]

Moves published Cloudflare tunnel ingress for hostnames defined in the
flake-generated route inventory at:
  ~/.config/cloudflare/route-inventory.json

If a hostname has multiple published path routes, like `ai.denneen.net`,
all of that hostname's inventory entries move together.

By default this updates the tunnel ingress only.
Pass --also-dns to move the matching CNAME records too.

Requires:
  CLOUDFLARE_API_TOKEN / CF_API_TOKEN
  CLOUDFLARE_ACCOUNT_ID / CF_ACCOUNT_ID (falls back to inventory accountId)
EOF
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "cf-move-published-routes: missing required command: $1" >&2
    exit 1
  }
}

require_cmd curl
require_cmd jq
require_cmd mktemp

move_dns=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --also-dns|--dns)
      move_dns=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "cf-move-published-routes: unsupported flag '$1'" >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

inventory_path="${CLOUDFLARE_ROUTE_INVENTORY_PATH:-${XDG_CONFIG_HOME:-$HOME/.config}/cloudflare/route-inventory.json}"
token="${CLOUDFLARE_API_TOKEN:-${CF_API_TOKEN:-}}"

if [[ ! -r "$inventory_path" ]]; then
  echo "cf-move-published-routes: route inventory is not readable at $inventory_path" >&2
  exit 1
fi

account_id="$(
  CLOUDFLARE_ACCOUNT_ID="${CLOUDFLARE_ACCOUNT_ID:-}"
  CF_ACCOUNT_ID="${CF_ACCOUNT_ID:-}"
  jq -r --arg envAccountId "${CLOUDFLARE_ACCOUNT_ID:-${CF_ACCOUNT_ID:-}}" '
    if $envAccountId != "" then $envAccountId else (.accountId // "") end
  ' "$inventory_path"
)"
zone_name="$(
  CLOUDFLARE_ZONE_NAME="${CLOUDFLARE_ZONE_NAME:-}"
  jq -r --arg envZoneName "${CLOUDFLARE_ZONE_NAME:-}" '
    if $envZoneName != "" then $envZoneName else (.zoneName // "") end
  ' "$inventory_path"
)"
dns_type="$(jq -r '.dnsDefaults.type // "CNAME"' "$inventory_path")"
dns_ttl="$(jq -r '.dnsDefaults.ttl // 1' "$inventory_path")"
dns_proxied="$(jq -r '.dnsDefaults.proxied // true' "$inventory_path")"

if [[ -z "$token" ]]; then
  echo "cf-move-published-routes: CLOUDFLARE_API_TOKEN is not set" >&2
  exit 1
fi

if [[ -z "$account_id" ]]; then
  echo "cf-move-published-routes: CLOUDFLARE_ACCOUNT_ID is not set" >&2
  exit 1
fi

target="$1"
shift || true

target_tunnel_id="$(jq -r --arg target "$target" '.tunnels[$target].id // empty' "$inventory_path")"
if [[ -z "$target_tunnel_id" ]]; then
  echo "cf-move-published-routes: unsupported target tunnel '$target'" >&2
  jq -r '.tunnels | keys[]' "$inventory_path" | sed 's/^/  - /' >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  mapfile -t default_hostnames < <(
    jq -r --arg target "$target" '
      [
        .publishedRoutes[]
        | select(.serviceByTunnel[$target]? != null)
        | .hostname
      ]
      | unique[]
    ' "$inventory_path"
  )
  if [[ "${#default_hostnames[@]}" -eq 0 ]]; then
    echo "cf-move-published-routes: inventory has no published routes for target '$target'" >&2
    exit 1
  fi
  set -- "${default_hostnames[@]}"
fi

api() {
  local method="$1"
  local url="$2"
  local body_file="${3:-}"

  if [[ -n "$body_file" ]]; then
    curl -fsS -X "$method" \
      -H "Authorization: Bearer $token" \
      -H "Content-Type: application/json" \
      --data @"$body_file" \
      "$url"
  else
    curl -fsS -X "$method" \
      -H "Authorization: Bearer $token" \
      -H "Content-Type: application/json" \
      "$url"
  fi
}

route_count_for_hostname() {
  local hostname="$1"

  jq -r --arg hostname "$hostname" --arg target "$target" '
    [
      .publishedRoutes[]
      | select(.hostname == $hostname)
    ]
    | length
  ' "$inventory_path"
}

owners_for_hostname() {
  local hostname="$1"

  jq -r --arg hostname "$hostname" '
    [
      .publishedRoutes[]
      | select(.hostname == $hostname)
      | .owner
    ]
    | unique
    | join(",")
  ' "$inventory_path"
}

routes_for_hostname() {
  local hostname="$1"

  jq -c --arg hostname "$hostname" --arg target "$target" '
    .publishedRoutes[]
    | select(.hostname == $hostname and (.serviceByTunnel[$target]? != null))
    | (
        { hostname: .hostname }
        + (if has("path") then { path: .path } else { } end)
        + { service: .serviceByTunnel[$target], originRequest: { } }
      )
  ' "$inventory_path"
}

mapfile -t known_tunnels < <(
  jq -r '.tunnels | to_entries[] | "\(.key):\(.value.id)"' "$inventory_path"
)

target_url="https://api.cloudflare.com/client/v4/accounts/${account_id}/cfd_tunnel/${target_tunnel_id}/configurations"
target_lookup="$(api GET "https://api.cloudflare.com/client/v4/accounts/${account_id}/cfd_tunnel/${target_tunnel_id}")"
if [[ "$(jq -r '.success' <<<"$target_lookup")" != "true" ]]; then
  echo "cf-move-published-routes: unable to read target tunnel ${target_tunnel_id}" >&2
  jq <<<"$target_lookup" >&2
  exit 1
fi

hostnames_file="$(mktemp)"
routes_file="$(mktemp)"
routes_lines_file="$(mktemp)"
empty_routes_file="$(mktemp)"
cleanup() {
  rm -f "$hostnames_file" "$routes_file" "$routes_lines_file" "$empty_routes_file"
}
trap cleanup EXIT

printf '%s\n' "$@" | jq -R . | jq -s 'unique' > "$hostnames_file"

: > "$routes_lines_file"
for hostname in "$@"; do
  route_count="$(route_count_for_hostname "$hostname")"
  if [[ "$route_count" == "0" ]]; then
    echo "cf-move-published-routes: hostname '$hostname' is not defined in publishedRoutes inventory" >&2
    exit 1
  fi

  owners="$(owners_for_hostname "$hostname")"
  if [[ -n "$owners" && ",$owners," != *",$target,"* ]]; then
    echo "cf-move-published-routes: warning: inventory owner for $hostname is $owners; moving to $target may drift until modules/shared/cloudflare-route-inventory.nix is updated" >&2
  fi

  route_lines="$(routes_for_hostname "$hostname")"
  if [[ -z "$route_lines" ]]; then
    if [[ -n "$owners" ]]; then
      echo "cf-move-published-routes: hostname '$hostname' is not configured for target '$target' in inventory (current owner: $owners)" >&2
    else
      echo "cf-move-published-routes: hostname '$hostname' is not configured for target '$target' in inventory" >&2
    fi
    exit 1
  fi

  printf '%s\n' "$route_lines" >> "$routes_lines_file"
done

jq -s '.' "$routes_lines_file" > "$routes_file"

printf '[]\n' > "$empty_routes_file"

build_payload() {
  local config_json="$1"
  local routes_json_file="$2"

  jq \
    --slurpfile hostnames "$hostnames_file" \
    --slurpfile routes "$routes_json_file" \
    '
      .result.config as $cfg
      | (($cfg.ingress // [])
          | map(select(.service == "http_status:404"))
          | last // { service: "http_status:404" }) as $default
      | {
          config: {
            ingress: (
              (($cfg.ingress // [])
                | map(select(.service != "http_status:404"))
                | map(select(((.hostname? // "") as $h | ($hostnames[0] | index($h)) == null)))
              ) + $routes[0] + [ $default ]
            ),
            "warp-routing": ($cfg["warp-routing"] // { enabled: false })
          }
        }
    ' <<<"$config_json"
}

echo "Updating published routes on ${target}..."
target_config="$(api GET "$target_url")"
target_payload="$(mktemp)"
build_payload "$target_config" "$routes_file" > "$target_payload"
target_update="$(api PUT "$target_url" "$target_payload")"
rm -f "$target_payload"
if [[ "$(jq -r '.success' <<<"$target_update")" != "true" ]]; then
  echo "cf-move-published-routes: failed to update target tunnel ${target}" >&2
  jq <<<"$target_update" >&2
  exit 1
fi

for tunnel in "${known_tunnels[@]}"; do
  tunnel_name="${tunnel%%:*}"
  tunnel_id="${tunnel##*:}"
  if [[ "$tunnel_id" == "$target_tunnel_id" ]]; then
    continue
  fi

  echo "Removing moved hostnames from ${tunnel_name}..."
  tunnel_url="https://api.cloudflare.com/client/v4/accounts/${account_id}/cfd_tunnel/${tunnel_id}/configurations"
  tunnel_config="$(api GET "$tunnel_url")"
  tunnel_payload="$(mktemp)"
  build_payload "$tunnel_config" "$empty_routes_file" > "$tunnel_payload"
  tunnel_update="$(api PUT "$tunnel_url" "$tunnel_payload")"
  rm -f "$tunnel_payload"

  if [[ "$(jq -r '.success' <<<"$tunnel_update")" != "true" ]]; then
    echo "cf-move-published-routes: failed to update tunnel ${tunnel_name}" >&2
    jq <<<"$tunnel_update" >&2
    exit 1
  fi
done

echo "Published routes now on ${target}:"
api GET "$target_url" |
  jq -r '.result.config.ingress[] | select(.hostname? != null) | [.hostname, (.path // "-"), .service] | @tsv'

if [[ "$move_dns" == "true" ]]; then
  zone_lookup="$(api GET "https://api.cloudflare.com/client/v4/zones?name=${zone_name}")"
  zone_id="$(jq -r '.result[0].id // empty' <<<"$zone_lookup")"

  if [[ -z "$zone_id" ]]; then
    echo "cf-move-published-routes: unable to resolve zone id for ${zone_name}" >&2
    jq <<<"$zone_lookup" >&2
    exit 1
  fi

  target_content="${target_tunnel_id}.cfargotunnel.com"
  echo "Updating DNS records to ${target}..."

  for hostname in "$@"; do
    lookup="$(api GET "https://api.cloudflare.com/client/v4/zones/${zone_id}/dns_records?name=${hostname}")"
    record_id="$(jq -r '.result[0].id // empty' <<<"$lookup")"
    current_content="$(jq -r '.result[0].content // empty' <<<"$lookup")"
    current_type="$(jq -r '.result[0].type // empty' <<<"$lookup")"

    if [[ -z "$record_id" ]]; then
      echo "cf-move-published-routes: no DNS record found for ${hostname}" >&2
      jq <<<"$lookup" >&2
      exit 1
    fi

    if [[ "$current_type" != "$dns_type" ]]; then
      echo "cf-move-published-routes: ${hostname} is ${current_type}, expected ${dns_type}" >&2
      exit 1
    fi

    body_file="$(mktemp)"
    jq -cn \
      --arg type "$dns_type" \
      --arg name "$hostname" \
      --arg content "$target_content" \
      --argjson ttl "$dns_ttl" \
      --argjson proxied "$dns_proxied" \
      '{type:$type,name:$name,content:$content,ttl:$ttl,proxied:$proxied}' > "$body_file"
    api PUT "https://api.cloudflare.com/client/v4/zones/${zone_id}/dns_records/${record_id}" "$body_file" >/dev/null
    rm -f "$body_file"

    echo "${hostname}: ${current_content} -> ${target_content}"
  done
fi
